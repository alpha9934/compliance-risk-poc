# ── Upstash Kafka ──────────────────────────────────────────────
UPSTASH_KAFKA_BOOTSTRAP_SERVERS=your-cluster.upstash.io:9092
UPSTASH_REDIS_REST_URL="https://sweet-civet-105265.upstash.io"
UPSTASH_REDIS_REST_TOKEN="gQAAAAAAAZsxAAIgcDE4NDYyOWFhMzhjMTg0MjViYTU2YmY0NWY4OTU2ZWJmZQ"
UPSTASH_KAFKA_TOPIC=compliance-transactions

# ── Upstash Redis ──────────────────────────────────────────────
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your-redis-token

# ── Neon PostgreSQL ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/compliance_poc?sslmode=require
DATABASE_URL_SYNC=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/compliance_poc?sslmode=require

# ── LLM APIs ───────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key          # console.cloud.google.com
GROQ_API_KEY=your-groq-api-key              # console.groq.com

# ── MCP server ─────────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8001         # local dev
# MCP_SERVER_URL=https://your-mcp.onrender.com  # production

# ── App settings ───────────────────────────────────────────────
APP_ENV=development                          # development | production
SECRET_KEY=change-me-to-a-random-secret-key-32chars
LOG_LEVEL=INFO
MODEL_PATH=models/xgboost_v1.json

# ── DagsHub (MLflow tracking) ──────────────────────────────────
MLFLOW_TRACKING_URI=https://dagshub.com/YOUR_USERNAME/compliance-risk-poc.mlflow
MLFLOW_TRACKING_USERNAME=your-dagshub-username
MLFLOW_TRACKING_PASSWORD=your-dagshub-token
